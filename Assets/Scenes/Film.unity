    - target: {fileID: 5914256563449222504, guid: a33feaf72b66e4aa8bfaaf2bd53d2e53,
        type: 3}
      propertyPath: m_text
      value: '<!delay=0.05>The year xyz:RE0.

        <!wait=1>The Solar system''s
        star, the Sun, is dying.

        <!wait=1>Life on Earth as we know it will
        soon be over.

        <!wait=1>Humanity currently weighs its options.

        <!wait=1>Astronauts
        are being sent to space to gather data.

        <!wait=1>One such astronaut
        is called Major Tom.

        <!wait=1>He is to explore a minor blackhole
        in the far reaches of the galaxy!'
      objectReference: {fileID: 0}
